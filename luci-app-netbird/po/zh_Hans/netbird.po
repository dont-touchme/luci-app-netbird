# v3.1 版本管理重设计新增串

msgid "Custom download"
msgstr "自定义下载"

msgid "Update now (v%s)"
msgstr "立即更新(v%s)"

msgid "Download"
msgstr "下载"

msgid "Downloaded versions"
msgstr "已下载版本"

msgid "Switch to this version"
msgstr "切换到此版本"

msgid "Delete"
msgstr "删除"

msgid "Delete version"
msgstr "删除版本"

msgid "Delete failed."
msgstr "删除失败。"

msgid "In use"
msgstr "使用中"

msgid "Binary installed: v%s."
msgstr "已安装二进制：v%s。"

msgid "Deleted version v%s."
msgstr "已删除版本 v%s。"

msgid "Enter a custom download URL first."
msgstr "请先填入自定义下载链接。"

msgid "If no local copy is kept, it will be fetched from the %s feed first."
msgstr "若本机未保留副本，将先从 %s 软件源获取。"

msgid "Delete downloaded custom version v%s? This only removes the stored binary file."
msgstr "删除已下载的自定义版本 v%s?仅删除存储的二进制文件。"

msgid "No custom versions downloaded yet. Enter a URL above and click Download."
msgstr "尚无已下载的自定义版本。在上方填入链接并点击「下载」。"

msgid "No local %s binary copy is kept; switching will fetch it from the %s feed automatically (%s)."
msgstr "本机未保留 %s 二进制副本;切换时将自动从 %s 软件源获取(%s)。"

msgid "The %s feed does not provide netbird on this device, so switching is unavailable. Check your package sources."
msgstr "本机 %s 软件源未提供 netbird,无法切换。请检查软件源配置。"

msgid "Download the NetBird client from a custom URL, kept by version so you can roll back anytime."
msgstr "从自定义链接下载 NetBird 客户端，按版本号保存，随时可退回。"

msgid "A NetBird tarball or a direct binary URL; after download it is checked against this CPU architecture."
msgstr "NetBird 压缩包或二进制直链，下载后会自动校验包是否符合当前 CPU。"

# v3.1 review 手测:撞词消歧 + 防火墙澄清

msgid "Allow NetBird peers to reach your LAN (src=netbird, dest=lan). Higher exposure, enable with care. No effect if Block Inbound is enabled on the Settings Firewall tab."
msgstr "允许 NetBird 对等节点访问您的局域网(src=netbird,dest=lan)。安全风险较高，请谨慎启用。若「设置 ▸ 防火墙」开启了「阻断入站」，本转发不生效。"

msgid "Block all inbound connections to this machine and routed networks (overrides management policies). This also blocks the NetBird to LAN forwarding on the Network tab."
msgstr "阻断所有到本机及路由网络的入站连接(优先级高于管理策略)。这也会阻断「网络」标签页的 NetBird → LAN 转发。"

msgid "NetBird's own firewall rules (mesh ACL) — separate from the OpenWrt zone and forwarding on the Network tab."
msgstr "NetBird 自身的防火墙规则（mesh ACL），与「网络」标签页的 OpenWrt 区域和转发是不同层。"

msgid "Select source"
msgstr "选择来源"

msgid "Switch source"
msgstr "切换"

# v5 方案 A:网络自动化改设备绑定 zone(去 network 接口概念)

msgid "Configure the OpenWrt firewall zone and forwarding rules for NetBird."
msgstr "为 NetBird 配置 OpenWrt 防火墙区域和转发规则。"

msgid "Creates a dedicated firewall zone bound to the NetBird device so NetBird traffic can flow."
msgstr "创建一个绑定到 NetBird 设备的专用防火墙区域，使 NetBird 流量得以通行。"

msgid "add/update zone %s bound to the NetBird device (input/output/forward=ACCEPT, masq, mtu_fix)."
msgstr "添加/更新绑定 NetBird 设备的区域 %s（input/output/forward=ACCEPT、masq、mtu_fix）。"

msgid "Create firewall zone"
msgstr "创建防火墙区域"

msgid "Remove firewall zone"
msgstr "移除防火墙区域"

msgid "Removes the NetBird firewall zone and both forwarding rules from OpenWrt. It does not stop the NetBird daemon or remove its wtX device; only the OpenWrt firewall plumbing is removed. Use this before uninstalling, or to undo the setup."
msgstr "从 OpenWrt 移除 NetBird 防火墙区域和两条转发规则。不会停止 NetBird 守护进程，也不会移除其 wtX 设备；仅移除 OpenWrt 防火墙配置。卸载前或撤销配置时使用。"

msgid "The NetBird firewall zone already exists."
msgstr "NetBird 防火墙区域已存在。"

msgid "The NetBird firewall zone does not exist yet. Use the \"Create firewall zone\" button below."
msgstr "NetBird 防火墙区域尚未创建。请使用下方的「创建防火墙区域」按钮。"

msgid "Firewall zone (bound device)"
msgstr "防火墙区域(绑定设备)"

msgid "The NetBird firewall zone is configured (device: %s)."
msgstr "NetBird 防火墙区域已配置(设备:%s)。"

msgid "The NetBird firewall zone was auto-created (prerequisite for forwarding)."
msgstr "已自动创建 NetBird 防火墙区域(转发的前置依赖)。"

# v5.2 状态页对端连接列标签:Connection -> Connection mode(连接模式,更准确)
msgid "Connection mode"
msgstr "连接模式"

# v5.3 认证页"重新连接"按钮(已连接态;do_down→do_up,转发流自愈)
msgid "Reconnect"
msgstr "重新连接"

msgid "NetBird reconnected."
msgstr "NetBird 已重新连接。"

msgid "Reconnect re-establishes the NetBird session while keeping your identity (down then up)."
msgstr "重新连接会断开后重新建立 NetBird 会话(down 再 up),登录身份保留。"

msgid "Invalid management URL (expected http(s)://host[:port])."
msgstr "管理 URL 格式非法（应为 http(s)://host[:port]）。"

msgid "The custom URL must start with http:// or https://."
msgstr "自定义链接必须以 http:// 或 https:// 开头。"

msgid "Could not fetch or parse the latest version from GitHub (network failure or unexpected format)."
msgstr "无法从 GitHub 获取或解析最新版本号（网络失败或格式异常）。"

msgid "The downloaded file is not a valid ELF executable; installation aborted."
msgstr "下载的文件不是合法的 ELF 可执行文件，已中止安装。"

msgid "The netbird daemon did not stop in time; replacement aborted to protect the current binary."
msgstr "netbird 守护进程未能及时停止，已中止替换以保护当前二进制。"

msgid "source must be release, opkg, or custom."
msgstr "source 必须是 release、opkg 或 custom。"

msgid "The release binary is not downloaded yet — use \"Check for updates / Update now\" first."
msgstr "Release 二进制尚未下载——请先用「检测更新 / 立即更新」安装。"

msgid "Switching to the custom source requires a valid version."
msgstr "切换到自定义来源需指定合法的版本号。"

msgid "The system package feed does not provide netbird, so its binary cannot be fetched automatically. Check your package sources, or use the release or custom source."
msgstr "系统软件源未提供 netbird，无法自动获取其二进制。请检查软件源，或改用 release / 自定义来源。"

msgid "The netbird daemon did not stop in time; switch aborted (the binary was not touched)."
msgstr "netbird 守护进程未能及时停止，已中止切换（未改动二进制）。"

msgid "The version is missing or invalid."
msgstr "版本号为空或非法。"

msgid "The netbird binary is not installed."
msgstr "netbird 二进制未安装。"

msgid "The binary path is empty."
msgstr "二进制路径为空。"

msgid "\"status --json\" did not return JSON."
msgstr "「status --json」返回的不是 JSON。"

msgid "Another binary operation is in progress; please wait and try again."
msgstr "另一个二进制操作正在进行，请稍后重试。"

msgid "Insecure download"
msgstr "不安全的下载"

msgid "Settings were saved, but the firewall reload did not complete; they will take effect on the next firewall reload or reboot."
msgstr "设置已保存，但防火墙重载未完成；将在下次防火墙重载或重启后生效。"

msgid "Checksum (optional)"
msgstr "校验值"

msgid "Checksum verification failed; the download was rejected."
msgstr "校验值不匹配，已拒绝下载。"

msgid "Not enough storage space. Delete unused downloaded versions and try again."
msgstr "存储空间不足。请删除未使用的已下载版本后重试。"

msgid "optional — md5 / sha1 / sha256 / sha512 hex"
msgstr "可选——md5 / sha1 / sha256 / sha512 十六进制"

msgid "If set, the download must match this checksum or it is rejected. Use sha256 or stronger for tamper protection; md5/sha1 only guard against corruption."
msgstr "若填写，下载物强制校验，否则自动拒绝。抗篡改请用 sha256 及以上；md5/sha1 仅能防意外损坏。"

msgid "Enter a valid checksum: md5 (32), sha1 (40), sha256 (64) or sha512 (128) hex characters."
msgstr "请输入合法校验和：md5（32）、sha1（40）、sha256（64）或 sha512（128）位十六进制字符。"

msgid "This is a plain http:// URL with no checksum. The downloaded file is executed as root, so a malicious mirror or a man-in-the-middle could run arbitrary code. Prefer https://, or paste a checksum above."
msgstr "这是明文 http:// 链接且未填校验和。下载物会以 root 执行，恶意镜像或中间人可借此运行任意代码。建议改用 https://，或在上方填入校验和。"

msgid "The checksum must be md5 (32), sha1 (40), sha256 (64) or sha512 (128) hexadecimal characters."
msgstr "校验和必须是 md5（32）、sha1（40）、sha256（64）或 sha512（128）位十六进制字符。"

msgid "Deregister"
msgstr "注销"

msgid "Deregister this NetBird device?"
msgstr "注销此 NetBird 设备？"

msgid "Daemon version is the running daemon; CLI version is the binary on disk. They match unless the binary was switched without restarting the daemon."
msgstr "守护进程版本为正在运行的 daemon；CLI 版本为磁盘上的二进制。二者通常相同，仅在切换二进制后未重启 daemon 时不同。"

