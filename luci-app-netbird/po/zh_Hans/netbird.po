msgstr "(两条转发规则)"

msgid "Your LAN/WAN configuration is not touched. The NetBird daemon keeps running and its wtX device stays up."
msgstr "不会触碰您的 LAN/WAN 配置。NetBird 守护进程继续运行，其 wtX 设备保持在线。"

msgid "Remove"
msgstr "移除"

msgid "NetBird network automation removed. If you later change network settings and NetBird loses connectivity, reconnect once from the Authentication page to restore it."
msgstr "已移除 NetBird 网络自动化配置。如之后修改网络设置导致 NetBird 连接异常，在「认证」页点一次「连接」重连即可恢复。"

msgid "Failed to remove automation."
msgstr "移除自动化配置失败。"

